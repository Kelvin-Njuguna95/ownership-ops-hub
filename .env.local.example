# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored and must NEVER be committed.

# Supabase project URL — same as the one embedded in deploy/index.html.
SUPABASE_URL=https://isccbmgjgtdosiccstcp.supabase.co

# Service role key — grab it from Supabase Dashboard → Settings → API.
# This key bypasses Row-Level Security and can write to any bucket. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=paste-your-service-role-key-here

# Airtable base ID — moved out of source (security phase 2). Required: the poll
# scripts read os.environ["AIRTABLE_BASE_ID"] and exit at import if it's unset.
AIRTABLE_BASE_ID=appHZdfC2sn9MLGFZ

# Optional: path to the real roster JSON. Defaults to private-notes/roster.json,
# falling back to config/roster.example.json (placeholders). In CI the roster is
# materialized from the ROSTER_JSON secret instead.
# ROSTER_PATH=private-notes/roster.json
