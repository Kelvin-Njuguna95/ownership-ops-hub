# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed.
# This file contains ONLY variable names + placeholders — no real values.

# Supabase project URL — Settings → API → Project URL.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service role key — Settings → API. Bypasses Row-Level Security; keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Airtable personal access token — read access to the ownership base.
AIRTABLE_PAT=your-airtable-pat

# Airtable base ID — the poll scripts read os.environ["AIRTABLE_BASE_ID"].
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Optional: path to the real roster JSON (defaults to private-notes/roster.json,
# then config/roster.example.json). In CI it's materialized from ROSTER_JSON.
# ROSTER_PATH=private-notes/roster.json

# Optional: Slack incoming webhook for the stale-uploads alert.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
